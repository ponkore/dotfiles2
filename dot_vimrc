syntax enable
set nonumber
nnoremap <leader>n :set number!<CR>
set directory=~/.config/vimfiles/swap//
set viminfo+=n~/.config/vimfiles/viminfo
let g:netrw_home = '~/.config/vimfiles'
set runtimepath+=~/.config/vimfiles
set wrap

" 検索系
set ignorecase
set smartcase
set incsearch
set wrapscan
set hlsearch
nmap <Esc><Esc> :nohlsearch<CR><Esc>

" clipboard
" set clipboard&
" set clipboard^=unnamedplus
set clipboard=unnamed

" F5で vimrc を reload
nnoremap <F5> :source $MYVIMRC<CR>

" .cshtml を HTML として扱う
autocmd BufNewFile,BufRead *.cshtml set filetype=html

" vim-plug
call plug#begin('~/.config/vimfiles/plugged')

Plug 'lambdalisue/vim-fern'

" #2
let g:fern#default_hidden = 1

nnoremap <silent> <C-n> :Fern . -drawer -toggle -reveal=%<CR>

Plug 'lambdalisue/fern-renderer-nerdfont.vim'
Plug 'lambdalisue/nerdfont.vim'

augroup FernCustom
  autocmd FileType fern nmap <buffer> H <Plug>(fern-action-leave)
  autocmd FileType fern setlocal nonumber
augroup End

" #3
let g:fern#renderer = 'nerdfont'

" preview for fern
Plug 'yuki-yano/fern-preview.vim'

" LSP server
Plug 'prabirshrestha/vim-lsp'
Plug 'mattn/vim-lsp-settings'

call plug#end()

" 全ウィンドウを保存して終了
nnoremap ZZ :wqa<CR>
