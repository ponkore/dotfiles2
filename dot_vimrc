syntax enable
set number
set directory=~/.config/vimfiles/swap//
set viminfo+=n~/.config/vimfiles/viminfo
let g:netrw_home = '~/.config/vimfiles'
set runtimepath+=~/.config/vimfiles
set wrap

" 検索系
set ignorecase
set smartcase
set incsearch
set wrapscan
set hlsearch
nmap <Esc><Esc> :nohlsearch<CR><Esc>

" clipboard
" set clipboard&
" set clipboard^=unnamedplus
set clipboard=unnamed

" F5で vimrc を reload
nnoremap <F5> :source $MYVIMRC<CR>

" .cshtml を HTML として扱う
autocmd BufNewFile,BufRead *.cshtml set filetype=html

" vim-plug
call plug#begin('~/.config/vimfiles/plugged')

Plug 'lambdalisue/vim-fern'
" #1
function! OnVimEnter()
  call timer_start(10, {_ -> execute('Fern . -drawer -reveal=%')})
endfunction
autocmd VimEnter * call OnVimEnter()

" #2
let g:fern#default_hidden = 1

Plug 'lambdalisue/fern-renderer-nerdfont.vim'
Plug 'lambdalisue/nerdfont.vim'

" #3
let g:fern#renderer = 'nerdfont'

" preview for fern
Plug 'yuki-yano/fern-preview.vim'

call plug#end()
